<addon id="plugin.video.pluto_free" version="0.0.1" name="Pluto Free (Custom)">
  <extension point="xbmc.python.pluginsource" library="default.py" />
  <extension point="xbmc.addon.metadata">
    <summary>Pluto Free Channels (M3U)</summary>
    <description>Pluto TV free channels addon that uses an M3U from your deployed site.</description>
    <platform>all</platform>
    <language>en</language>
  </extension>
  <extension point="xbmc.addon.settings">
    <settings>
      <category label="General">
        <setting id="base_url" type="string" label="Site Base URL" default="https://your-deploy.vercel.app" />
      </category>
    </settings>
  </extension>
</addon>
